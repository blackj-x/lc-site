---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { cmdCategories, commands, dataUpdatedAt } from '../data/terminal';

const title = '致命公司终端指令大全:航线/商店/雷达全指令';
const description = `致命公司(Lethal Company)飞船终端全 ${commands.length} 条指令速查:航线规划、商店购买、生物图鉴、雷达摄像头与远程开门,附用法示例与效果说明。`;

// 按分类分组,沿用 JSON 中 categories 的定义顺序
const groups = Object.entries(cmdCategories).map(([key, cat]) => ({
  key,
  ...cat,
  list: commands.filter((c) => c.category === key),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Article', headline: title, description, dateModified: dataUpdatedAt },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: '终端指令' },
      ],
    },
  ],
};
---
<Base title={title} description={description} jsonLd={jsonLd} active="terminal">
  <div class="wrap detail">
    <div class="crumb"><a href="/">首页</a> / 终端指令</div>
    <h1>终端<span class="em">指令大全</span></h1>
    <p class="lead">飞船终端是全队的大脑:规划航线、买装备、看摄像头、远程开门都靠它。全 {commands.length} 条指令按用途分类,留船的人照着打就行。</p>

    <AdSlot variant="top" />

    <div class="detail-layout">
      <main>
        <section class="sec mech">
          <h2>⌨️ 先记住两条输入机制</h2>
          <ul class="tips">
            <li><strong>不区分大小写</strong>:<code>moons</code>、<code>MOONS</code>、<code>Moons</code> 效果完全一样。</li>
            <li><strong>前 3 个字母即可识别</strong>:卫星名、物品名都支持前缀缩写,如 <code>ada</code> = Adamance。涉及消费的操作会要求再输 <code>confirm</code> 确认(<code>deny</code> 取消)。</li>
          </ul>
        </section>

        {groups.map((g) => (
          <section class="sec" id={`cat-${g.key}`}>
            <h2>{g.icon} {g.name}<span class="cat-count">{g.list.length} 条</span></h2>
            <div class="cmd-list">
              {g.list.map((c) => (
                <div class="cmd-row">
                  <div class="cmd-head">
                    <code class="cmd">{c.command}</code>
                    <span class="usage">用法:<code>{c.usage}</code></span>
                  </div>
                  <p class="effect">{c.effect}</p>
                  {'note' in c && (c as any).note && <p class="note">※ {(c as any).note}</p>}
                </div>
              ))}
            </div>
          </section>
        ))}
      </main>

      <aside>
        <AdSlot variant="side" />
      </aside>
    </div>
  </div>
</Base>

<style>
  .detail{padding-top:24px}
  h1{font-size:38px;font-weight:900;letter-spacing:-.5px;margin-top:6px}
  h1 .em{background:linear-gradient(120deg,var(--outdoor),var(--daytime) 50%,var(--indoor));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .lead{color:var(--txt-dim);font-size:16.5px;margin:14px 0 4px;max-width:720px}
  .detail-layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin-bottom:40px}
  .sec{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:24px;margin-bottom:18px}
  .sec h2{font-size:18px;color:var(--accent);margin-bottom:14px}
  .cat-count{font-size:12px;color:var(--txt-dim);font-weight:400;margin-left:10px}

  .tips{list-style:none;display:flex;flex-direction:column;gap:11px}
  .tips li{font-size:15px;color:var(--txt-dim);padding-left:20px;position:relative}
  .tips li::before{content:"▸";position:absolute;left:0;color:var(--accent)}
  .tips strong{color:var(--txt)}

  code{font-family:'SF Mono',Menlo,Consolas,monospace;background:var(--bg-elev);border:1px solid var(--line);border-radius:6px;padding:1px 7px;font-size:13px;color:var(--daytime)}

  .cmd-list{display:flex;flex-direction:column}
  .cmd-row{padding:14px 0;border-bottom:1px solid var(--line)}
  .cmd-row:last-child{border:0;padding-bottom:0}
  .cmd-row:first-child{padding-top:0}
  .cmd-head{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:6px}
  .cmd{font-size:15px;font-weight:700;text-transform:uppercase;color:var(--accent);padding:3px 10px;letter-spacing:.5px}
  .usage{font-size:12.5px;color:var(--txt-dim)}
  .usage code{color:var(--txt-dim);font-size:12px}
  .effect{font-size:14.5px;color:var(--txt)}
  .note{font-size:12.5px;color:var(--txt-dim);margin-top:4px}

  @media(max-width:920px){
    .detail-layout{grid-template-columns:1fr}
    h1{font-size:28px}
  }
</style>
