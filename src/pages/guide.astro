---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { entities, entityName, getEntity, categoryName } from '../data/entities';
import { moons, moonTitle } from '../data/moons';
import { items } from '../data/items';

const title = '新手指南：致命公司怎么玩？核心循环、生死铁律与中英术语表 - 致命公司攻略社';
const description =
  '致命公司（Lethal Company）新手入门：着陆→搜刮→满足配额的核心循环、5 条保命铁律（弹簧头/小丑盒子/蕨影怎么应对）、怪物物品中英术语对照速查表与常见问题，零基础快速上岗。';

// —— 事实全部从 JSON 数据引,不写死数字 ——
const freeMoons = moons.filter((m) => m.cost === 0);
const scrapItems = items.filter((i) => i.type === 'scrap');
const gordion = moons.find((m) => m.slug === 'gordion');
const expMoon = moons.find((m) => m.slug === 'experimentation');
const maxScrap = [...scrapItems]
  .filter((i) => i.value !== null)
  .sort((a, b) => b.value!.max - a.value!.max)[0];
const immortals = entities.filter((e) => e.immortal === true);

// 生死铁律 5 条:数值字段来自 entities 数据,机制描述保持通用
const ruleSlugs = ['coil-head', 'jester', 'bracken', 'eyeless-dog', 'earth-leviathan'] as const;
const ruleText: Record<string, { rule: string; why: string }> = {
  'coil-head': {
    rule: '盯着它就别移开视线',
    why: '它只在没人看它时移动。被追上一击伤害极高，倒着走、轮流对视撤离。',
  },
  jester: {
    rule: '听到摇柄音乐就立刻撤离',
    why: '上发条期间无害，一旦弹出进入追击状态。它不会出建筑，跑出大门就安全。',
  },
  bracken: {
    rule: '瞥一眼逼退，别长时间凝视',
    why: '短暂对视会让它后退；持续盯着会激怒它。被它从背后接近就是即死，走廊里勤回头。',
  },
  'eyeless-dog': {
    rule: '在室外保持安静、蹲走通过',
    why: '它没有视力，靠声音定位。说话、跑步、掉落物品都会引来扑咬。',
  },
  'earth-leviathan': {
    rule: '感到地面震动就立刻变向跑',
    why: '它从地下突袭，吞到就是即死。看到沙土隆起别直线跑，侧向拉开。',
  },
};
const rules = ruleSlugs
  .map((slug) => {
    const e = getEntity(slug);
    return e ? { e, ...ruleText[slug] } : null;
  })
  .filter(Boolean) as { e: NonNullable<ReturnType<typeof getEntity>>; rule: string; why: string }[];

// 中英术语速查表:从 entities + items 动态生成(SEO 长尾)
const termRows = [
  ...entities.map((e) => ({
    zh: entityName(e),
    en: e.nameEn,
    aliases: e.aliases.join('、'),
    type: '怪物',
    href: `/monsters/${e.slug}`,
  })),
  ...items.map((i) => ({
    zh: i.nameZh || i.nameEn,
    en: i.nameEn,
    aliases: i.aliases.join('、'),
    type: i.type === 'scrap' ? '废料' : i.type === 'tool' ? '工具' : '商店',
    href: '/items',
  })),
];

// FAQ:渲染与 JSON-LD 共用同一数组,答案里的数字来自上面的数据计算
const faqs = [
  {
    q: '致命公司的配额（Quota）是什么？',
    a: `公司每隔几天结算一次利润配额，到期前必须把足额废料卖给公司，否则全队出局。核心循环就是：选卫星着陆 → 进设施搜刮废料 → 回船 → 到${gordion ? moonTitle(gordion) : '公司大楼'}出售、满足配额。`,
  },
  {
    q: '哪些怪物无法击杀？',
    a: `根据本站收录的数据，${immortals.map((e) => entityName(e)).join('、')} 这 ${immortals.length} 种实体标记为无法击杀，只能躲避或拖延，不要浪费武器耐久。`,
  },
  {
    q: '新手先去哪颗卫星？',
    a: `本站收录 ${moons.length} 颗卫星，其中 ${freeMoons.length} 颗为免费航线。${expMoon ? `推荐先去 ${moonTitle(expMoon)}：风险评级 ${expMoon.tier} 级，废料 ${expMoon.scrapCount.min}–${expMoon.scrapCount.max} 件，适合熟悉流程。` : '优先选择免费且风险评级低的卫星熟悉流程。'}`,
  },
  {
    q: '废料价值怎么看？捡什么最值钱？',
    a: `本站物品价值表收录 ${items.length} 件物品，其中 ${scrapItems.length} 件为可出售废料，每件都标注了价值区间和重量。${maxScrap ? `例如${maxScrap.nameZh || maxScrap.nameEn}（${maxScrap.nameEn}）价值 ▮${maxScrap.value!.min}–${maxScrap.value!.max}。` : ''}优先拿价值/重量比高的，负重会拖慢移速和体力。`,
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Article', headline: title, description },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: '新手指南' },
      ],
    },
  ],
};
---
<Base title={title} description={description} jsonLd={jsonLd} active="guide">
  <div class="wrap detail">
    <div class="crumb"><a href="/">首页</a> / 新手指南</div>
    <h1>新手指南：<span class="em">致命公司怎么玩</span></h1>
    <p class="lead">一句话概括：你是公司新签约的合同工，开飞船去废弃卫星搜刮废料卖钱，在配额日之前赚够公司要的数——而卫星上的东西会吃人。下面带你从零上岗。</p>

    <AdSlot variant="top" />

    <div class="detail-layout">
      <main>
        <section class="sec">
          <h2>🔄 核心循环：着陆 → 搜刮 → 满足配额</h2>
          <ol class="flow">
            <li><strong>选卫星，着陆</strong>：在终端输入卫星名设定航线。本站收录 {moons.length} 颗卫星，{freeMoons.length} 颗免费航线（如 {freeMoons.slice(0, 3).map((m) => `${m.moonId}-${m.nameEn}`).join('、')}），付费卫星风险更高、废料也更值钱。每颗的风险评级、天气池、废料区间见<a href="/moons">卫星攻略</a>。</li>
            <li><strong>进设施搜刮</strong>：废料散落在设施内部。本站价值表收录 {scrapItems.length} 件废料，每件标注价值区间与重量——拿东西前先心里有个价。</li>
            <li><strong>天黑前回船</strong>：夜间室外刷新更危险的实体，贪刀是新人最常见的死法。留一名船员守<a href="/terminal">终端</a>报点、开关大门，效率翻倍。</li>
            <li><strong>去{gordion ? moonTitle(gordion) : '公司大楼'}卖货</strong>：把废料卖给公司满足配额。收购折扣随交货日临近变化，压到最后一天卖最划算，但别压到违约。</li>
          </ol>
        </section>

        <section class="sec">
          <h2>⚠️ 生死铁律 5 条</h2>
          <p class="hint">伤害 / 危险度 / 可否击杀均引自本站怪物档案数据字段，点名字看完整打法。</p>
          <div class="rules">
            {rules.map(({ e, rule, why }) => (
              <div class="rule">
                <div class="rule-head">
                  <a class="rule-name" href={`/monsters/${e.slug}`}>{entityName(e)}<small>{e.nameEn}</small></a>
                  <div class="rule-tags">
                    <span class="tag">{categoryName[e.category]}</span>
                    {e.immortal && <span class="tag warn">无法击杀</span>}
                    {e.attackDamage && <span class="tag">伤害 {e.attackDamage}</span>}
                    {e.powerLevel !== null && <span class="tag">危险度 {e.powerLevel}</span>}
                  </div>
                </div>
                <p><strong>{rule}</strong> —— {why}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="sec">
          <h2>📖 中英术语速查表</h2>
          <p class="hint">和队友联机、查英文资料时对得上号。中文名采用社区通行译名，常见俗称一并收录；共 {termRows.length} 条（{entities.length} 怪物 + {items.length} 物品）。</p>
          <div class="term-table-wrap">
            <table class="term-table">
              <thead>
                <tr><th>中文名</th><th>英文名</th><th>常见俗称</th><th>类别</th></tr>
              </thead>
              <tbody>
                {termRows.map((t) => (
                  <tr>
                    <td><a href={t.href}>{t.zh}</a></td>
                    <td class="en">{t.en}</td>
                    <td class="alias">{t.aliases || '—'}</td>
                    <td class="type">{t.type}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section class="sec">
          <h2>❓ 常见问题</h2>
          <dl class="terms">
            {faqs.map((f) => (
              <div class="term-row">
                <dt>{f.q}</dt>
                <dd>{f.a}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="sec next">
          <h2>👉 下一步</h2>
          <p>看完基础，去<a href="/monsters">怪物图鉴</a>把高危实体认全，或到<a href="/moons">卫星攻略</a>规划你的第一条航线，卖货前先翻<a href="/items">物品价值表</a>。</p>
        </section>
      </main>

      <aside>
        <AdSlot variant="side" />
      </aside>
    </div>
  </div>
</Base>

<style>
  .detail{padding-top:24px}
  h1{font-size:38px;font-weight:900;letter-spacing:-.5px;margin-top:6px}
  h1 .em{background:linear-gradient(120deg,var(--outdoor),var(--daytime) 50%,var(--indoor));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .lead{color:var(--txt-dim);font-size:16.5px;margin:14px 0 4px;max-width:720px}
  .detail-layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin-bottom:40px}
  .sec{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:24px;margin-bottom:18px}
  .sec h2{font-size:18px;color:var(--accent);margin-bottom:12px}
  .sec p{font-size:15.5px;color:var(--txt)}
  .sec a{color:var(--accent)}
  .hint{font-size:13px;color:var(--txt-dim);margin-bottom:14px!important}
  .flow{list-style:none;counter-reset:step;display:flex;flex-direction:column;gap:12px}
  .flow li{counter-increment:step;position:relative;padding-left:40px;font-size:15px;color:var(--txt-dim)}
  .flow li::before{content:counter(step);position:absolute;left:0;top:-2px;width:26px;height:26px;border-radius:8px;background:linear-gradient(135deg,var(--outdoor),var(--daytime));color:#14161a;font-weight:700;display:grid;place-items:center;font-size:13px}
  .flow strong{color:var(--txt)}
  .rules{display:flex;flex-direction:column;gap:14px}
  .rule{border-left:3px solid var(--indoor);padding-left:16px}
  .rule-head{display:flex;justify-content:space-between;gap:12px;align-items:baseline;flex-wrap:wrap;margin-bottom:6px}
  .rule-name{font-size:16px;font-weight:700;color:var(--txt)!important}
  .rule-name:hover{color:var(--accent)!important}
  .rule-name small{font-weight:400;color:var(--txt-dim);font-size:12px;margin-left:8px}
  .rule-tags{display:flex;gap:6px;flex-wrap:wrap}
  .rule-tags .tag{font-size:11px;color:var(--txt-dim);background:var(--bg-elev);border:1px solid var(--line);padding:3px 9px;border-radius:6px}
  .rule-tags .tag.warn{color:var(--indoor);border-color:rgba(255,84,112,.4)}
  .rule p{font-size:14.5px;color:var(--txt-dim)}
  .rule strong{color:var(--txt)}
  .term-table-wrap{overflow-x:auto;max-height:560px;overflow-y:auto;border:1px solid var(--line);border-radius:10px}
  .term-table{width:100%;border-collapse:collapse;font-size:14px}
  .term-table th{text-align:left;font-size:12px;color:var(--txt-dim);font-weight:700;letter-spacing:1px;padding:9px 12px;border-bottom:1px solid var(--line);position:sticky;top:0;background:var(--bg-elev);z-index:1}
  .term-table td{padding:9px 12px;border-bottom:1px solid var(--line);vertical-align:top}
  .term-table tr:last-child td{border-bottom:0}
  .term-table td a{color:var(--txt)}
  .term-table td a:hover{color:var(--accent)}
  .term-table .en{color:var(--txt-dim);font-size:13px}
  .term-table .alias{color:var(--txt-dim);font-size:13px}
  .term-table .type{color:var(--txt-dim);font-size:12px;white-space:nowrap}
  .terms{display:flex;flex-direction:column;gap:0}
  .term-row{display:grid;grid-template-columns:240px 1fr;gap:14px;padding:11px 0;border-bottom:1px solid var(--line)}
  .term-row:last-child{border:0}
  .term-row dt{font-weight:700;color:var(--accent);font-size:14.5px}
  .term-row dd{font-size:14px;color:var(--txt-dim)}
  .next p{color:var(--txt-dim)}
  @media(max-width:920px){
    .detail-layout{grid-template-columns:1fr}
    h1{font-size:28px}
    .term-row{grid-template-columns:1fr;gap:3px}
  }
</style>
