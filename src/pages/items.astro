---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { items, dataUpdatedAt } from '../data/items';

const title = '致命公司物品价值表:全废料售价与商店价格一览';
const description = `致命公司(Lethal Company)全 ${items.length} 件物品价值速查:废料售价区间、重量、是否导电、单双手与商店价格,支持按名称搜索、类型筛选与排序。`;

const typeName: Record<string, string> = { scrap: '废料', store: '商店装备', tool: '工具' };

// weight 字段约定:>1 部分 ×100 = 磅(见 items.schema.md)
const toLb = (w: number | null) => (w === null ? null : Math.round((w - 1) * 100));
const displayName = (i: (typeof items)[number]) => i.nameZh || i.nameEn;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Article', headline: title, description, dateModified: dataUpdatedAt },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: '物品价值表' },
      ],
    },
  ],
};
---
<Base title={title} description={description} jsonLd={jsonLd} active="items">
  <div class="wrap detail">
    <div class="crumb"><a href="/">首页</a> / 物品价值表</div>
    <h1>物品<span class="em">价值总表</span></h1>
    <p class="lead">全 {items.length} 件物品的售价区间、重量与属性速查。废料按出售价值排序找最值钱的目标,雷暴天先看「导电」一列。数据更新于 {dataUpdatedAt}。</p>

    <AdSlot variant="top" />

    <div class="detail-layout">
      <main>
        <section class="sec table-sec">
          <div class="toolbar">
            <input id="item-search" type="search" placeholder="搜索物品名(支持中英文与别名)…" autocomplete="off" />
            <div class="filters" id="type-filters">
              <button class="f-btn on" data-type="all">全部</button>
              <button class="f-btn" data-type="scrap">废料</button>
              <button class="f-btn" data-type="store">商店装备</button>
              <button class="f-btn" data-type="tool">工具</button>
            </div>
            <span class="count" id="item-count">共 {items.length} 件</span>
          </div>

          <div class="table-scroll">
            <table id="items-table">
              <thead>
                <tr>
                  <th data-key="name" data-kind="str">名称 <span class="arrow"></span></th>
                  <th data-key="type" data-kind="str">类型 <span class="arrow"></span></th>
                  <th data-key="value" data-kind="num">价值区间 <span class="arrow"></span></th>
                  <th data-key="weight" data-kind="num">重量 <span class="arrow"></span></th>
                  <th>导电</th>
                  <th>双手</th>
                  <th data-key="price" data-kind="num">商店价 <span class="arrow"></span></th>
                </tr>
              </thead>
              <tbody>
                {items.map((i) => {
                  const lb = toLb(i.weight);
                  return (
                    <tr
                      data-type={i.type}
                      data-search={[i.nameEn, i.nameZh, ...i.aliases].filter(Boolean).join(' ').toLowerCase()}
                      data-name={i.nameEn.toLowerCase()}
                      data-value={i.value ? i.value.max : -1}
                      data-weight={lb ?? -1}
                      data-price={i.storePrice ?? -1}
                    >
                      <td class="c-name">
                        <strong>{displayName(i)}</strong>
                        {i.nameZh && <span class="en">{i.nameEn}</span>}
                      </td>
                      <td><span class={`type-badge t-${i.type}`}>{typeName[i.type]}</span></td>
                      <td class="c-num">{i.value ? `${i.value.min}–${i.value.max}` : '—'}</td>
                      <td class="c-num">{lb !== null ? `${lb} 磅` : '—'}</td>
                      <td class="c-mid">{i.conductive === true ? <span class="cond">⚡ 是</span> : i.conductive === false ? '否' : '—'}</td>
                      <td class="c-mid">{i.twoHanded === true ? '双手' : i.twoHanded === false ? '单手' : '—'}</td>
                      <td class="c-num">{i.storePrice !== null ? `▸${i.storePrice}` : '—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          <p class="hint">点击表头可排序;价值与商店价单位为游戏内信用点;「—」表示该项不适用或暂无数据。</p>
        </section>
      </main>

      <aside>
        <AdSlot variant="side" />
      </aside>
    </div>
  </div>
</Base>

<script>
  const table = document.getElementById('items-table')!;
  const tbody = table.querySelector('tbody')!;
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const search = document.getElementById('item-search') as HTMLInputElement;
  const countEl = document.getElementById('item-count')!;
  const filterBox = document.getElementById('type-filters')!;
  let activeType = 'all';

  function applyFilter() {
    const q = search.value.trim().toLowerCase();
    let n = 0;
    for (const tr of rows) {
      const okType = activeType === 'all' || tr.dataset.type === activeType;
      const okSearch = !q || (tr.dataset.search || '').includes(q);
      const show = okType && okSearch;
      (tr as HTMLElement).style.display = show ? '' : 'none';
      if (show) n++;
    }
    countEl.textContent = `共 ${n} 件`;
  }

  search.addEventListener('input', applyFilter);
  filterBox.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.f-btn') as HTMLElement | null;
    if (!btn) return;
    filterBox.querySelectorAll('.f-btn').forEach((b) => b.classList.remove('on'));
    btn.classList.add('on');
    activeType = btn.dataset.type || 'all';
    applyFilter();
  });

  // 排序:数值列 null(-1)始终沉底;同列再点切换升/降
  let sortKey = '';
  let sortAsc = false;
  table.querySelectorAll('th[data-key]').forEach((th) => {
    th.addEventListener('click', () => {
      const key = (th as HTMLElement).dataset.key!;
      const kind = (th as HTMLElement).dataset.kind!;
      sortAsc = sortKey === key ? !sortAsc : kind === 'str';
      sortKey = key;
      const dir = sortAsc ? 1 : -1;
      const sorted = rows.slice().sort((a, b) => {
        if (kind === 'num') {
          const av = Number(a.dataset[key]);
          const bv = Number(b.dataset[key]);
          if (av === -1 && bv === -1) return 0;
          if (av === -1) return 1; // null 沉底
          if (bv === -1) return -1;
          return (av - bv) * dir;
        }
        return (a.dataset[key] || '').localeCompare(b.dataset[key] || '') * dir;
      });
      sorted.forEach((tr) => tbody.appendChild(tr));
      table.querySelectorAll('th .arrow').forEach((s) => (s.textContent = ''));
      const arrow = th.querySelector('.arrow');
      if (arrow) arrow.textContent = sortAsc ? '▲' : '▼';
    });
  });
</script>

<style>
  .detail{padding-top:24px}
  h1{font-size:38px;font-weight:900;letter-spacing:-.5px;margin-top:6px}
  h1 .em{background:linear-gradient(120deg,var(--outdoor),var(--daytime) 50%,var(--indoor));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .lead{color:var(--txt-dim);font-size:16.5px;margin:14px 0 4px;max-width:720px}
  .detail-layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin-bottom:40px}
  .sec{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:24px;margin-bottom:18px}
  .hint{font-size:13px;color:var(--txt-dim);margin-top:14px}

  .toolbar{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:16px}
  #item-search{flex:1;min-width:220px;background:var(--bg-elev);border:1px solid var(--line);border-radius:10px;padding:9px 14px;color:var(--txt);font-size:14px;font-family:inherit}
  #item-search:focus{outline:none;border-color:var(--accent)}
  .filters{display:flex;gap:6px}
  .f-btn{background:var(--bg-elev);border:1px solid var(--line);border-radius:8px;padding:7px 13px;color:var(--txt-dim);font-size:13px;cursor:pointer;font-family:inherit;transition:.15s}
  .f-btn:hover{color:var(--txt)}
  .f-btn.on{color:var(--accent);border-color:var(--accent);background:rgba(255,216,78,.08)}
  .count{font-size:13px;color:var(--txt-dim);margin-left:auto}

  .table-scroll{overflow-x:auto}
  table{width:100%;border-collapse:collapse;font-size:14px}
  th{position:sticky;top:0;text-align:left;font-size:12.5px;color:var(--txt-dim);font-weight:700;padding:10px 12px;border-bottom:2px solid var(--line);background:var(--bg-card);white-space:nowrap}
  th[data-key]{cursor:pointer;user-select:none}
  th[data-key]:hover{color:var(--txt)}
  .arrow{color:var(--accent);font-size:10px}
  td{padding:10px 12px;border-bottom:1px solid var(--line);color:var(--txt-dim);white-space:nowrap}
  tbody tr:hover{background:var(--bg-elev)}
  .c-name strong{color:var(--txt);font-weight:700}
  .c-name .en{display:block;font-size:11.5px;color:var(--txt-dim)}
  .c-num{font-variant-numeric:tabular-nums}
  .c-mid{font-size:13px}
  .cond{color:var(--daytime);font-weight:700}
  .type-badge{font-size:11px;font-weight:700;padding:3px 9px;border-radius:7px}
  .t-scrap{background:rgba(59,169,255,.14);color:var(--outdoor)}
  .t-store{background:rgba(255,216,78,.12);color:var(--daytime)}
  .t-tool{background:rgba(255,84,112,.14);color:var(--indoor)}

  @media(max-width:920px){
    .detail-layout{grid-template-columns:1fr}
    h1{font-size:28px}
    .table-sec{padding:16px}
  }
</style>
