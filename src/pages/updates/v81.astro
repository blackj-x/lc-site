---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getEntity, entityName, categoryName } from '../../data/entities';

const title = '致命公司 v81 更新解读：三连补丁、感染机制调参与黏鱼重做 - 致命公司攻略社';
const description =
  '致命公司（Lethal Company）v81 三个官方补丁全解读：Cadaver Bloom / Cadaver Growth 感染机制连续调参（满血感染率 -25%、低血量 +20%）、Backwater Gunkfish 行为重做与威胁度减半、绑匪狐狸新增逃巢行为、除草剂降价、OpenXR VR 支持回归，逐条整理并给出实战影响。';

// 与 entities.json 交叉：v81 三个补丁重点调整的实体（数值字段直接渲染，不手抄）
const patchedEntities = [
  {
    slug: 'cadaver-bloom',
    note: 'v81 修复最密集的实体：站桩过久、空中绽放缓降、落点偏移、电梯穿模、击杀后不生成尸体等问题逐一处理；Patch 3 起可被船舱监视器看到、也能像玩家一样被传送回船。',
  },
  {
    slug: 'cadaver-growth',
    note: '感染数值在 Patch 3 大调：蔓延到 7 个房间后扩散概率降低三分之一；满血玩家被感染概率 -25%，血量 ≤60 时 +20%，重伤流血状态靠近会大幅提高感染概率，血量同样影响发病速度。',
  },
  {
    slug: 'backwater-gunkfish',
    note: 'Patch 1 起水下蹲行不再被黏液减速（可通过水下洞穴）；Patch 2 行为重做：换位更快、不再贴脸落点、个体间错开站位，威胁等级（power level）减半、更倾向成群刷新。',
  },
  {
    slug: 'feiopar',
    note: 'Patch 2 修复死亡后远距离尖叫音频不停止的问题——再听到远处持续嚎叫，说明附近还有活的。',
  },
  {
    slug: 'kidnapper-fox',
    note: 'Patch 1 新增行为：远离巢穴时被打到且已受创，会主动逃回巢穴躲避——追击残血狐狸前先想想它要把你引去哪。',
  },
].map((x) => ({ ...x, e: getEntity(x.slug) })).filter((x) => x.e);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Article', headline: title, description, datePublished: '2026-06-07', inLanguage: 'zh-CN' },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: '版本解读' },
        { '@type': 'ListItem', position: 3, name: 'v81' },
      ],
    },
  ],
};

const SRC_STEAM = 'https://store.steampowered.com/news/app/1966720/view/516365152240535509';
const SRC_WIKI = 'https://lethal.miraheze.org/wiki/Version_81';
const SRC_DISCUSS = 'https://steamcommunity.com/app/1966720/discussions/0/802343728582946328/';
---
<Base title={title} description={description} jsonLd={jsonLd} active="updates">
  <div class="wrap detail">
    <div class="crumb"><a href="/">首页</a> / 版本解读 / v81</div>
    <h1>v81 更新解读：<span class="em">三连补丁，把 v80 拧紧</span></h1>
    <p class="lead">v80 大版本（2026-04-05 出公测）落地后，开发者 Zeekerss 在 4 月上旬连发三个补丁（v81 Patch 1–3），核心是把新怪 Cadaver Bloom / Growth 的感染机制和 Backwater Gunkfish 的行为调到能玩——这三个补丁直接决定了 v80 新内容的实际手感，打森林卫星前务必过一遍。</p>

    <AdSlot variant="top" />

    <div class="detail-layout">
      <main>
        <section class="sec">
          <h2>📋 版本概览</h2>
          <ul class="kv">
            <li><strong>性质</strong>：v80「The Blooming Update」之后的三个修复 / 平衡补丁（v81 Patch 1 / 2 / 3），非内容向大版本</li>
            <li><strong>推送时间</strong>：均在 2026 年 4 月上旬（社区 Wiki 存档页 2026-04-10 已收录全部三个补丁；官方未对单个补丁标注精确日期）</li>
            <li><strong>发布渠道</strong>：补丁说明由开发者在 Discord 发布，社区 Wiki 与 Steam 讨论区存档转录——Steam 商店页没有独立公告，这也是中文圈几乎零覆盖的原因</li>
            <li><strong>三大主线</strong>：① Cadaver 感染系怪物的修复与数值调参；② Gunkfish 行为重做 + 威胁度减半；③ 一批 v80 引入的同步 / 物理 / 地图问题修复</li>
          </ul>
          <p class="srcline">来源：<a href={SRC_WIKI} rel="noopener" target="_blank">Lethal Company Wiki「Version 81」官方 patch log 存档</a> / <a href={SRC_DISCUSS} rel="noopener" target="_blank">Steam 社区讨论区补丁转录</a></p>
        </section>

        <section class="sec">
          <h2>👾 本次调整涉及的实体（图鉴已收录）</h2>
          <p class="hint">以下属性数值取自本站图鉴数据库，与图鉴页同源；逐条注明所属补丁。</p>
          <ul class="ent-list">
            {patchedEntities.map(({ e, note }) => (
              <li class="ent-row">
                <div class="ent-head">
                  <a class="ent-name" href={`/monsters/${e!.slug}`}>{entityName(e!)}</a>
                  <span class="ent-en">{e!.nameZh ? e!.nameEn : ''}</span>
                  <span class={`badge ${e!.category}`}>{categoryName[e!.category]}</span>
                  <span class="indexed">图鉴已收录 →</span>
                </div>
                <p class="ent-note">{note}</p>
                <div class="ent-stats">
                  {e!.powerLevel != null && <span class="tag">危险等级 {e!.powerLevel}</span>}
                  {e!.hp && <span class="tag">HP {e!.hp}</span>}
                  {e!.maxCount != null && e!.maxCount > 0 && <span class="tag">单日上限 {e!.maxCount}</span>}
                  {e!.immortal === true && <span class="tag">无法击杀</span>}
                </div>
              </li>
            ))}
          </ul>
          <p>v81 没有新增可遭遇实体，但有两项「新增内容」值得记：<strong>OpenXR 插件</strong>回到游戏文件中（原版默认禁用，目的是让 VR mod 在着色器更新后继续可用）；<strong>HUD 电池量表与图标改为常显</strong>（暗化处理），配合 v80 的工具栏位让道具状态一目了然。</p>
        </section>

        <section class="sec">
          <h2>⚙️ 机制变化（按补丁逐条）</h2>
          <h3>Patch 1：感染怪修复 + 体验打磨</h3>
          <ul class="tips">
            <li><strong>Cadaver Bloom 五连修</strong>：控制玩家后无目标时不再长时间站桩；空中绽放不再缓慢飘落、落点不再偏离正下方；矿井电梯内绽放不再穿模；被击杀时正常生成玩家尸体。</li>
            <li><strong>Cadaver Growth 修复</strong>：此前若 Cadaver Bloom 被摧毁（例如被沙虫吞掉），Growth 会无法再生成绽放体——已修复。</li>
            <li><strong>Gunkfish 黏液豁免</strong>：水下 + 蹲行同时满足时黏液不生效，水下洞穴从此可以通行。</li>
            <li><strong>绑匪狐狸逃巢行为</strong>：受创且远离巢穴时被攻击，会逃回巢穴。</li>
            <li><strong>杂项</strong>：低头丢物品落在脚下（堵死穿墙丢物）、Vain Shroud 可在雪地卫星生长并有积雪外观、除草剂导致次日地图加载失败的 bug 修复、蹲走镜头晃动减轻（防晕动症）、蜂巢不再刷在深水区。</li>
          </ul>
          <h3>Patch 2：Gunkfish 重做 + 同步修复</h3>
          <ul class="tips">
            <li><strong>Gunkfish 行为重做</strong>：换位决策更快、不再选玩家贴脸位置、多条鱼互相错开；威胁等级减半、更倾向成群出现——从「单体恶心」改成「群体骚扰」。</li>
            <li><strong>Old Birds 修复</strong>：开机即起飞、对非房主隐身但仍能开火追击的恶性 desync 均修复。</li>
            <li><strong>OpenXR 插件</strong>：加入游戏文件（原版禁用），为 VR mod 续命。</li>
            <li><strong>杂项</strong>：Masked 可被公司巡洋舰碾压、Snare Flea 不再叠抱已被缠住的玩家头部、防火出口进出朝向修正、Bracken 攻击非房主时瞬间加速的问题修复、March 船位附近跳点几何微调。</li>
          </ul>
          <h3>Patch 3：感染数值大调 + 落点优化</h3>
          <ul class="tips">
            <li><strong>感染概率与血量挂钩</strong>：满血玩家被 Cadaver Growth 感染概率 -25%；血量 ≤60 时 +20%；重伤流血状态靠近植株感染概率大幅上升。血量同样影响感染发病速度。</li>
            <li><strong>蔓延减速</strong>：Growth 蔓延到 7 个房间后，向新房间扩散的概率降低三分之一。</li>
            <li><strong>除草剂增强</strong>：价格从 25 降到 20；被除草剂治疗可清除「长时间待在植株中」对病程速度的残留加成。</li>
            <li><strong>Cadaver Bloom 可监控 / 可传送</strong>：船舱监视器能看到它，也能像玩家一样被传送回船。</li>
            <li><strong>杂项</strong>：反向传送器落点计算改进（尽量落在走廊 / 房间中央，不卡进管道家具）、感染者面部孢子特效可见性修复、March 扫描节点 / AI 节点 / 防火出口刷石头等地图问题修复、腰包落地漂浮修复。</li>
          </ul>
          <p class="srcline">来源：<a href={SRC_WIKI} rel="noopener" target="_blank">Lethal Company Wiki「Version 81」</a>（官方 patch log 存档，原文由 Zeekerss 在 Discord 发布）/ <a href={SRC_DISCUSS} rel="noopener" target="_blank">Steam 社区讨论区转录</a></p>
        </section>

        <section class="sec">
          <h2>🧭 对玩家的影响解读</h2>
          <ul class="tips">
            <li><strong>满血进设施不再是口号</strong>：感染概率和发病速度都吃血量，Patch 3 之后「残血硬探」面对 Cadaver Growth 的期望损失明显变大。残血队友别派去清感染区，先回船吃药。</li>
            <li><strong>除草剂从除草工具升级为感染解药</strong>：降价 + 清除病程残留加成，森林卫星常备一瓶的性价比上来了，正好放 v80 新增的工具栏位里。</li>
            <li><strong>Bloom 绽放不再等于减员</strong>：监视器可见 + 可传送回船，留守终端位多了一个硬活——看到 Bloom 图标直接拉传送，能把「队友变怪」的雪球掐掉。</li>
            <li><strong>Gunkfish 应对思路反转</strong>：单条威胁下降但常成群，水下路线靠「蹲行潜泳」就能过黏液区；遇到鱼群优先绕行而不是清场。</li>
            <li><strong>残血狐狸别追</strong>：它会把你引回巢穴，巢穴附近才是它的主场。</li>
            <li><strong>VR 玩家可以回坑了</strong>：OpenXR 插件回归意味着 VR mod 生态在新着色器下能继续维护，关注你用的 mod 是否已适配 v81。</li>
          </ul>
        </section>

        <section class="sec next">
          <h2>👉 下一步</h2>
          <p>v81 调整的怪物详细数值与应对策略见 <a href="/monsters">怪物图鉴</a>；这些改动的来龙去脉（新怪、工具栏位、March 重做）见 <a href="/updates/v80">v80 大版本解读</a>。</p>
        </section>

        <section class="sec meta">
          <p>本文基于 Steam 官方公告 + 社区实测整理，更新于 2026-06-07。引用来源：
            <a href={SRC_WIKI} rel="noopener" target="_blank">lethal.miraheze.org/wiki/Version_81</a>（官方 patch log 存档）·
            <a href={SRC_STEAM} rel="noopener" target="_blank">Steam 官方公告「Version 80」</a> ·
            <a href={SRC_DISCUSS} rel="noopener" target="_blank">Steam 社区讨论区 v81 补丁转录</a>。
            实体属性数值与本站图鉴数据库同源；单个补丁的精确推送日期官方未标注，本文不做推断。</p>
        </section>
      </main>

      <aside>
        <AdSlot variant="side" />
      </aside>
    </div>
  </div>
</Base>

<style>
  .detail{padding-top:24px}
  h1{font-size:38px;font-weight:900;letter-spacing:-.5px;margin-top:6px}
  h1 .em{background:linear-gradient(120deg,var(--outdoor),var(--daytime) 50%,var(--indoor));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .lead{color:var(--txt-dim);font-size:16.5px;margin:14px 0 4px;max-width:720px}
  .detail-layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin-bottom:40px}
  .sec{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:24px;margin-bottom:18px}
  .sec h2{font-size:18px;color:var(--accent);margin-bottom:12px}
  .sec h3{font-size:15px;color:var(--txt);margin:18px 0 10px}
  .sec h3:first-of-type{margin-top:0}
  .sec p{font-size:15.5px;color:var(--txt)}
  .hint{font-size:13px;color:var(--txt-dim);margin-bottom:14px!important}
  .kv{list-style:none;display:flex;flex-direction:column;gap:9px}
  .kv li{font-size:15px;color:var(--txt-dim);padding-left:18px;position:relative}
  .kv li::before{content:"▸";position:absolute;left:0;color:var(--accent)}
  .kv strong{color:var(--txt)}
  .srcline{font-size:12.5px!important;color:var(--txt-dim)!important;margin-top:14px}
  .srcline a{color:var(--outdoor)}
  .srcline a:hover{text-decoration:underline}
  .ent-list{list-style:none;display:flex;flex-direction:column;gap:0;margin-bottom:14px}
  .ent-row{padding:14px 0;border-bottom:1px solid var(--line)}
  .ent-row:last-child{border:0}
  .ent-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px}
  .ent-name{font-size:16.5px;font-weight:700;color:var(--txt)}
  .ent-name:hover{color:var(--accent)}
  .ent-en{font-size:12.5px;color:var(--txt-dim)}
  .indexed{margin-left:auto;font-size:12px;color:var(--daytime)}
  .ent-note{font-size:14px;color:var(--txt-dim)!important;margin-bottom:8px}
  .ent-stats{display:flex;gap:6px;flex-wrap:wrap}
  .tips{list-style:none;display:flex;flex-direction:column;gap:11px}
  .tips li{font-size:15px;color:var(--txt-dim);padding-left:20px;position:relative}
  .tips li::before{content:"▸";position:absolute;left:0;color:var(--accent)}
  .tips strong{color:var(--txt)}
  .tips a{color:var(--outdoor)}
  .tips a:hover{text-decoration:underline}
  .next p{color:var(--txt-dim)}
  .next a{color:var(--accent)}
  .meta{background:var(--bg-elev)}
  .meta p{font-size:12.5px;color:var(--txt-dim)}
  .meta a{color:var(--outdoor)}
  @media(max-width:920px){
    .detail-layout{grid-template-columns:1fr}
    h1{font-size:28px}
  }
</style>
